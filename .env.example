# Copy to .env and fill in. .env is gitignored.

# ─── GMI Cloud — runs PixVerse t2v through GMI's inference cloud ────
GMI_API_KEY=
GMI_T2V_MODEL=pixverse-v5.6-t2v
GMI_LLM_BASE_URL=https://api.gmi-serving.com
GMI_LLM_MODEL=Qwen/Qwen3-Next-80B-A3B-Instruct

# ─── OpenAI — embeddings only (text-embedding-3-small) ─────
OPENAI_API_KEY=

# ─── PixVerse (direct, fallback only — usually leave blank) ─────
# PIXVERSE_API_KEY=

# ─── Photon Spectrum (iMessage) ─────────────────────────────
PHOTON_PROJECT_ID=
PHOTON_PROJECT_SECRET=
PHOTON_API_BASE=https://spectrum.photon.codes

# ─── HydraDB — vector memory for cross-user resonance ─────
HYDRA_API_KEY=
HYDRA_BASE_URL=https://api.hydradb.com
HYDRA_NAMESPACE=dream_walker

# ─── Server ─────────────────────────────────────────────────
PORT=8000
PUBLIC_URL=http://localhost:8000
